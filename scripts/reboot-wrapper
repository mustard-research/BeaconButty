#!/usr/bin/env bash
# Wrapper: intercepts 'sudo reboot' and calls bb-reboot for a clean shutdown.
# Pass --force (or -f) to skip bb-reboot and call the real binary directly.

for arg in "$@"; do
    if [[ "$arg" == "--force" || "$arg" == "-f" ]]; then
        # Strip the flag before exec: to the real reboot, -f/--force means a
        # HARD reboot (skips systemd shutdown entirely — no ClickHouse stop,
        # no clean unmounts), the opposite of what "skip bb-reboot's extras"
        # intends on this box.
        args=()
        for a in "$@"; do
            [[ "$a" == "--force" || "$a" == "-f" ]] || args+=("$a")
        done
        exec /usr/sbin/reboot "${args[@]}"
    fi
done

exec /usr/local/bin/bb-reboot
