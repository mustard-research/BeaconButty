# BeaconButty local overrides — site-specific values that should NOT live in
# version control. Copy this file to /etc/beaconbutty/local.env on the
# deployed system and edit. The webapp, healthcheck, alert script, and
# Python timers all source it automatically when present.
#
# Every variable has a sensible default — anything left unset just falls
# back to the example value (which is enough to boot, but not enough to
# alert correctly).

# Hostname used in the TLS certificate path and in the webapp's outbound
# links. If you don't have TLS configured, leave the default; the cert
# block in app.py will fail gracefully and serve plain HTTP on port 8080.
BB_HOST=beaconbutty.local

# LAN range Zeek captures on. Used by ja4-threat-check.py,
# ja4-history-update.py, and seed-assets-history.py to distinguish
# internal from external IPs.
BB_LAN_SUBNET=192.168.50.0/24

# The Pi's eth1 IP — also the LAN gateway and DHCP/DNS server address.
BB_LAN_GATEWAY_IP=192.168.50.1

# The Pi's eth1 MAC. l2-alert-check.sh compares every ARP "I am the
# gateway" announcement against this; mismatch fires a gateway-impersonation
# alert. You MUST set this correctly or every legitimate ARP reply from
# the Pi will look like a takeover.
#
# Find your value with:  ip -o link show eth1 | awk '{print $17}'
BB_LAN_GATEWAY_MAC=aa:bb:cc:dd:ee:ff

# Optional. Slack channel name shown in the Health page's "Clear channel"
# button label. Leave blank if you don't use the Slack integration.
BB_SLACK_CHANNEL=

# Base directory for Let's Encrypt certificate output. The webapp expects
# fullchain.pem and privkey.pem at $BB_TLS_CERT_DIR/$BB_HOST/.
BB_TLS_CERT_DIR=/etc/letsencrypt/live

# Optional. Tailscale MagicDNS hostname for tailscale-cert-renew.sh; find
# yours with `tailscale status --json | jq -r .Self.DNSName`. Leave blank
# if the box isn't on a tailnet — the renew script then no-ops.
BB_TS_CERT_HOST=

# AWS Lambda alert endpoint + shared secret. Required for alert.sh to fire.
# The Lambda function reads the secret from its own SHARED_SECRET env var;
# both values must match. Generate a new secret with `openssl rand -hex 32`
# and set it on both the Pi (here) and the Lambda function configuration.
BB_ALERT_URL=
BB_ALERT_SECRET=
