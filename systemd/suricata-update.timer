[Unit]
Description=BeaconButty — daily Suricata rule update at 06:00

[Timer]
# Run at 06:00, one hour before the daily beacon report (07:00),
# so the latest threat signatures are active before that run.
OnCalendar=*-*-* 06:00:00
# Spread load — don't hammer the ET servers at exactly 06:00
RandomizedDelaySec=1800
Persistent=true

[Install]
WantedBy=timers.target
